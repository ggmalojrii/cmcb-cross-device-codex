# CMCB v18.27 environment placeholders.
# Copy this outside synced folders before adding real values.
# Do not commit real secrets.

CMCB_CENTRAL_ROOT=V:\CMCB-Central
CMCB_SHARED_ROOT=V:\CMCB-Central\CMCB-Shared

CLOUD_PROVIDER=
CLOUD_REGION=
CLOUD_VM_NAME=cmcb-codex-worker
CLOUD_VM_SIZE=
CLOUD_VM_DISK_GB=200
CLOUD_BUDGET_MONTHLY_USD=

# Terraform variables. Prefer exporting these in the shell instead of writing real values here.
TF_VAR_vm_name=cmcb-codex-worker
TF_VAR_region=
TF_VAR_instance_type=
TF_VAR_root_volume_gb=200
TF_VAR_ssh_public_key=
TF_VAR_allowed_ssh_cidr=

# SSH
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# Tailscale
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=cmcb-codex-vm
TAILSCALE_TAGS=tag:codex-worker
CMCB_APPROVE_TAILSCALE_UP=0

# VM package installs
CMCB_APPROVE_APT_INSTALL=0
CMCB_APPROVE_CODEX_INSTALL=0

# Codex/OpenAI
OPENAI_API_KEY=
CODEX_AUTH_MODE=interactive

# Git
GIT_REMOTE_URL=

# Artifact/log sync
SYNC_PROVIDER=syncthing
SYNCTHING_DEVICE_ID_DESKTOP=
SYNCTHING_DEVICE_ID_LAPTOP=
SYNCTHING_DEVICE_ID_VM=
RCLONE_CONFIG=
